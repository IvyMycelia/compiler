import <stdio>

struct Vector2 {
    x: int,
    y: int
}

struct Vector3 {
    x: int,
    y: int,
    z: int
}

prop int test():
    p: @Vector2 = new Vector2
    p.x = 5
    p.y = 10
    if p.x == 5:
        if p.y == 10:
            p2: @Vector3 = new Vector3
            p2.x = 1
            p2.y = 2
            p2.z = 3
            if p2.z == 3:
                return 1
            end
            prune p2
        end
    end

    prune p
    return 0
end