import <stdio>
import <stdlib>

import "./memory/memory.flo" as memory
import "./types/types.flo" as types
import "./control/control.flo" as control
import "./io/io.flo" as io
import "./misc/misc.flo" as misc
import "./import/import.flo" as imports

int main():
    total: int = 0
    pass: int = 0

    print("\n=== Memory ===\n")
    total = total + 1
    pass = pass + memory.test()

    print("\n=== Types ===\n")
    total = total + 1
    pass = pass + types.test()

    print("\n=== Control ===\n")
    total = total + 1
    pass = pass + control.test()

    print("\n=== IO ===\n")
    total = total + 1
    pass = pass + io.test()

    print("\n=== Misc ===\n")
    total = total + 1
    pass = pass + misc.test()

    print("\n=== Import ===\n")
    total = total + 1
    pass = pass + imports.test()

    print("\n=== Results ===\n")
    if pass == total:
        print("All Passed!\n")
    else:
        print("Some Failed!\n")
    end

    return 0
end