import <stdio>

import "./examples/io/print.flo" as prints

prop int test():
    total: int = 0
    pass: int = 0

    print("  print... ")
    total = total + 1
    print("\'")
    if prints.test() == 1:
        print("\' ")
        pass = pass + 1
        print("OK\n")
    else:
        print("FAIL\n")
    end

    if pass == total:
        print("  IO: All Passed!\n")
    else:
        print("  IO: Some Failed!\n")
    end

    return pass == total
end