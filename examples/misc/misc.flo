import <stdio>

import "examples/misc/fibonacci.flo" as fibonacci

prop int test():
    total: int = 0
    pass: int = 0

    print("  fibonacci... ")
    total = total + 1
    if fibonacci.test() == 55:
        pass = pass + 1
        print("OK\n")
    else:
        print("FAIL\n")
    end

    if pass == total:
        print("  Misc: All Passed!\n")
    else:
        print("  Misc: Some Failed!\n")
    end

    return pass == total
end