import <stdio>
import <stdlib>

import "./examples/import/math.flo" as math

prop int test():    
    total: int = 0
    pass: int = 0

    print("  math.. ")
    total = total + 1
    if math.add(1, 2) == 3:
        pass = pass + 1
        print("OK\n")
    else:
        print("FAIL\n")
    end

    if pass == total:
        print("  Import: All Passed!\n")
    else:
        print("  Import: Some Failed!\n")
    end

    return pass == total
end