{
    "name": "flower-language",
    "displayName": "Flower Language Support",
    "description": "Syntax highlighting for Flower",
    "version": "1.0.0",
    "engines": {
        "vscode": "^1.60.0"
    },
    "activationEvents": [
        "onLanguage:flower"
    ],
    "main": "./index.js",
    "contributes": {
        "languages": [
        {
            "id": "flower",
            "aliases": [
            "Flower"
            ],
            "extensions": [
            ".flo"
            ],
            "configuration": "./language-configuration.json"
        }
        ],
        "grammars": [
        {
            "language": "flower",
            "scopeName": "source.flower",
            "path": "./syntaxes/flower.tmLanguage.json"
        }
        ]
    }
}