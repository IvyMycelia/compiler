{
    "name": "Flower",
    "scopeName": "source.flo",
    "fileTypes": [ "flo" ],
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#types"
        }
    ],

    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.flower",
                    "match": "//.*$"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.flower",
                    "match": "\\b(if|else|while|for|return|break|continue|end|in)\\b"
                },
                {
                    "name": "keyword.other.flower",
                    "match": "\\b(import|as|prop|new|prune|print|sizeof|struct|union|forward|null|not|and|or)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.flower",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.flower",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "mame": "string.quoted.single.flower",
                    "begin": "'",
                    "end": "'"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.flower",
                    "match": "\\b\\d+(\\.\\d+)?\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.flower",
                    "match": "(\\+|-|\\*|/|@|&|=|==|!=|!|<|>|<=|>=)"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.flower",
                    "match": "\\b(int|float|double|char|void|string|bool)\\b"
                }
            ]
        }

    }
}