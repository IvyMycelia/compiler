{
    "comments": {
        "lineComment": "//"
    },

    "brackets": [
        [ "(", ")" ],
        [ "[", "]" ],
        [ "{", "}" ]
    ],

    "indentationRules": {
        "increaseIndentPattern": "(if|while|for|else|struct|union)\\s*:$)",
        "decreaseIndentPattern": "^\\s*end"
    }
}