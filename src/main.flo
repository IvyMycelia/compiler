import <stdio>
import <string>
import <ctype>
import <stdlib>
import <unistd>

import "src/globals.flo" as globals
import "src/lexer.flo" as lexer
import "src/ast.flo" as parser
import "src/parser.flo" as parser
import "src/file.flo" as file
import "src/codegen.flo" as codegen

int main(argc: int, argv: @char[]):
    getcwd(project_root, sizeof(project_root));
    if argc < 2:
        printf("%sMissing arguments! Use -help for usage instructions.%s\n", RED, RESET)
        return -1
    end

    for i in 1..argc:
        arg: @char = argv[i]

        if arg[0] == '-':
            // Skip all leading dashes
            while arg[0] == '-':
                arg = arg + 1
            end

            for i in 0..strlen(arg):
                arg[i] = tolower(arg[i] as char)
            end

            if not strcmp(arg, "help") or not strcmp(arg, "h"):
                printf("%s🌸 Welcome to Flower Compiler!\n\n%s", GREEN, RESET)
        
                printf("%sUsage:\n%s", BLUE, RESET)
                print("\tflower\t[options] <filepath>\n\n")

                printf("%sOptions:\n%s", BLUE, RESET)
                print("\t-help,    -h\tShow this help message\n")
                print("\t-version, -v\tShow the current version of FloC\n")
                print("\t<filepath>\tSpecify the source code file to compile\n\n")
        
                printf("%sExample:\n%s", BLUE, RESET)
                print("\tflower -help\n")
                print("\tflower main.flo\n\n")
        
                printf("%sTips:\n%s", BLUE, RESET)
                print(" - You can use any number of dashes before a flag, e.g., ---help\n")
                print(" - Flags are case-insensitive: -HELP works too!\n\n")
        
                printf("%sHappy Compiling with Flower! 🌼\n%s", GREEN, RESET)
                continue
            else if not strcmp(arg, "version") or not strcmp(arg, "v"):
                print("Version: 0.0.4\n")
                continue
            else:
                printf("%sUnrecognized flag argument! Use -help for more information.\n%s", RED, RESET)
            end
        else:
            printf("%sCompiling file: %s%s\n", BLUE, argv[i], RESET)
            
            abs_path: char[512]
            realpath(argv[i], abs_path)
            set_current_file(abs_path)

            file: @char = file.read_file(argv[i])
            if not file:
                return -1
            end


            // Initialize token handling
            tokens: @TokenStream = new TokenStream
            lexer.init_token_stream(tokens)

            // Lexer
            print("Lexing...\n"); fflush(stdout)
            lexer.lex(tokens, file)
            // lexer.print_all_tokens(tokens, file)

            // printf("sizeof AST: %d\n", sizeof(AST))
            // printf("sizeof Token: %d\n", sizeof(Token))
            // printf("sizeof TokenStream: %d\n", sizeof(TokenStream))

            // Parser
            print("Parsing...\n"); fflush(stdout)
            tree: Parser;
            parser.init_parser(&tree, tokens, file, argv[i])
            ast: @AST = parser.parse(&tree)

            // Codegen
            out_c: char[512]
            if i + 1 < argc and argv[i + 1][0] != '-':
                snprintf(out_c, sizeof(out_c), "%s.c", argv[i + 1])
            else:
                snprintf(out_c, sizeof(out_c), "output.c")
            end

            output: @FILE = fopen(out_c, "w")
            if not output:
                printf("%sFailed to open output file\n%s", RED, RESET)
                return -1
            end

            has_output: int = 0
            if token_stream_contains(tokens, TOKEN_PRINT):
                has_output = 1
            end

            print("Codegen...\n"); fflush(stdout)
            emit_includes(ast, output, file, tokens)
            codegen(ast, output, file)

            free_token_stream(tokens)
            prune file
            fclose(output)

            bin_name: char[512]
            snprintf(bin_name, sizeof(bin_name), "%.*s", (strlen(out_c) - 2) as int, out_c)

            build_cmd: char[1024]
            snprintf(build_cmd, sizeof(build_cmd), "clang %s -o %s", out_c, bin_name)

            system(build_cmd)

            if has_output:
                printf("%s\nOUTPUT:\n", YELLOW)
                fflush(stdout)
                printf("%s", RESET)
                fflush(stdout)
                snprintf(build_cmd, sizeof(build_cmd), "./%s", bin_name)
            end

            system(build_cmd)
            print("\n")
            printf("%sCompiled %s → %s%s\n", GREEN, out_c, bin_name, RESET)
            break
        end
    end
end