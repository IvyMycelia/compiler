project_root: char[512]

current_file: @char

void set_current_file(f: @char):
    current_file = f
end

RED:    @char   =   "\033[0;31m"
YELLOW: @char   =   "\033[0;33m"
GREEN:  @char   =   "\033[0;32m"
RESET:  @char   =   "\033[0m"
BLUE:   @char   =   "\033[0;34m"
BOLD:   @char   =   "\033[1m"

@char resolve_path(importing_file: @char, import_path: @char):
    if import_path[0] == '<': return null
    end

    resolved: char[1024]
    if (import_path[0] == '.' and import_path[1] == '/') or (import_path[0] == '.' and import_path[1] == '.' and import_path[2] == '/'):
        dir: char[1024]
        strncpy(dir, importing_file, sizeof(dir) - 1)
        dir[sizeof(dir) - 1] = '\0'

        last_slash: @char = strrchr(dir, '/')
        if last_slash:
            last_slash = last_slash + 1
            @last_slash = '\0'
        else: strcpy(dir, "./")
        end

        if strlen(dir) + strlen(import_path) >= sizeof(resolved):
            printf("%sPath too long: %s%s%s\n", RED, dir, import_path, RESET)
            return null
        end

        snprintf(resolved, sizeof(resolved), "%s%s", dir, import_path + 2)
    else:
        snprintf(resolved, sizeof(resolved), "%s/%s", project_root, import_path)
    end
    return strdup(resolved)
end